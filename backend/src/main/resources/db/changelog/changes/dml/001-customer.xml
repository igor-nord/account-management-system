<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="dml-001-customer-seed" author="igor">
        <insert tableName="customer">
            <column name="id" valueNumeric="1"/>
            <column name="username" value="demo"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

    <changeSet id="dml-001-customer-seed-more" author="igor">
        <insert tableName="customer">
            <column name="id" valueNumeric="2"/>
            <column name="username" value="alice"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="customer">
            <column name="id" valueNumeric="3"/>
            <column name="username" value="bob"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

    <changeSet id="dml-001-customer-seed-demo-history" author="igor">
        <insert tableName="customer">
            <column name="id" valueNumeric="4"/>
            <column name="username" value="johndoe"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="customer">
            <column name="id" valueNumeric="5"/>
            <column name="username" value="janedoe"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

</databaseChangeLog>
