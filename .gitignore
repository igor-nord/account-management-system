# Root .gitignore — GLOBAL ignores only (OS + IDE).
# Subproject build artifacts are owned by their own .gitignore files:
#   backend/.gitignore   — Java/Gradle build output + H2 database files
#   frontend/.gitignore  — Node/Angular build output + caches
# Git applies all of them automatically for their respective subtrees.

# OS
.DS_Store
Thumbs.db

# IntelliJ IDEA (IDE project files — regenerated from Gradle/CLI, not committed)
.idea/
*.iml
*.iws
*.ipr
out/

# Logs (cross-cutting)
*.log

# H2
*.db
